# Discord Bot Token
# Get this from: https://discord.com/developers/applications
# 1. Select your application
# 2. Go to "Bot" section
# 3. Copy the token under "TOKEN"
BOT_TOKEN=your_bot_token_here

# Discord OAuth2 Client ID
# Get this from: https://discord.com/developers/applications
# 1. Select your application
# 2. Go to "OAuth2" > "General"
# 3. Copy the "Client ID"
CLIENT_ID=your_client_id_here

# Discord OAuth2 Client Secret
# Get this from: https://discord.com/developers/applications
# 1. Select your application
# 2. Go to "OAuth2" > "General"
# 3. Click "Reset Secret" and copy it
CLIENT_SECRET=your_client_secret_here

# Your Discord Server (Guild) ID
# How to get it:
# 1. Enable Developer Mode in Discord (User Settings > Advanced > Developer Mode)
# 2. Right-click your server name
# 3. Click "Copy Server ID"
GUILD_ID=your_guild_id_here

# OAuth2 Redirect URI
# This must match EXACTLY what you set in Discord Developer Portal
# Format: http://localhost:3000/auth/callback (for local development)
# Or: https://yourdomain.com/auth/callback (for production)
REDIRECT_URI=http://localhost:3000/auth/callback

# Server Port
PORT=3000

# Environment
NODE_ENV=development
